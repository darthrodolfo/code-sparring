  "last_maintenance_time": "2025-11-01T08:30:00Z",
  "base_location": {
    "latitude": 30.4058,
    "longitude": -86.4764
  },
  "specs": {
    "max_speed_kmh": 1960,
    "wingspan_meters": 13.56,
    "range_km": 2960,
    "max_altitude_meters": 19812,
