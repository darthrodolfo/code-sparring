{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach by Process ID",
      "processId": "${command:PickProcess}",
      "request": "attach",
      "skipFiles": ["<node_internals>/**"],
      "type": "node"
    },
    {
      "name": "Attach",
      "port": 9229,
      "request": "attach",
      "skipFiles": ["<node_internals>/**"],
      "type": "node"
    },
    {
      "command": "npm start",
      "name": "Run npm start",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "name": ".NET Core Launch (web)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/backend-csharp/bin/Debug/net9.0/backend-csharp.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend-csharp",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      }
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    },
    {
      "name": "Fastify Dev (port 3001)",
      "command": "npm run dev",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}/backend-node-fastify"
    },
    {
  "name": "Fastify Tests (all)",
  "type": "node",
  "request": "launch",
  "cwd": "${workspaceFolder}/backend-node-fastify",
  "runtimeExecutable": "node",
  "runtimeArgs": [
    "-r",
    "ts-node/register"
  ],
  "program": "${workspaceFolder}/backend-node-fastify/test/index.ts",
  "console": "integratedTerminal",
  "internalConsoleOptions": "neverOpen",
  "skipFiles": [
    "<node_internals>/**"
  ],
  "env": {
    "AIRCRAFT_DB_PATH": ":memory:"
  }
},
{
  "name": "Fastify Aircraft Test",
  "type": "node",
  "request": "launch",
  "cwd": "${workspaceFolder}/backend-node-fastify",
  "runtimeExecutable": "node",
  "runtimeArgs": [
    "-r",
    "ts-node/register"
  ],
  "program": "${workspaceFolder}/backend-node-fastify/test/routes/aircraft.test.ts",
  "console": "integratedTerminal",
  "internalConsoleOptions": "neverOpen",
  "skipFiles": [
    "<node_internals>/**"
  ],
  "env": {
    "AIRCRAFT_DB_PATH": ":memory:"
  }
}

  ]
}

